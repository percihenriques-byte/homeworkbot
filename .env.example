# Variáveis de ambiente para rodar FORA do Manus.
# Copie pra .env.local (local) ou configure no painel do host (Render/Railway).

# --- Banco de dados (obrigatório) ---
# MySQL/TiDB. Pegue grátis no TiDB Cloud Serverless (tidbcloud.com).
DATABASE_URL=mysql://usuario:senha@host:4000/homeworkbot?sslaccept=strict

# --- Login (obrigatório) ---
# A senha de acesso ao site (quem souber, entra).
APP_PASSWORD=troque-esta-senha
# Segredo pra assinar o cookie de sessão (qualquer texto longo e aleatório).
JWT_SECRET=troque-por-um-texto-aleatorio-bem-longo

# --- IA / Jarvis (grátis) ---
# Chave grátis do Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=cole-sua-chave-gemini-aqui
# Opcional (padrão gemini-2.5-flash):
# GEMINI_MODEL=gemini-2.5-flash

# --- Modo demonstração (opcional) ---
# DEMO_MODE=true faz o app abrir SEM login, num usuário "Visitante" fixo.
# Só pra mostrar o produto. NUNCA use em produção com dados reais.
# DEMO_MODE=true

# --- E-mail de lembretes (opcional) ---
# Se quiser lembretes por e-mail: Gmail + Senha de App (configura na tela de Configurações).

# --- Cron externo (opcional; grátis) ---
# Se você quer disparar lembretes/sync-toddle automaticamente com um cron
# externo (cron-job.org, GitHub Actions, EasyCron), defina um segredo aqui e
# passe no header `x-cron-secret` nas chamadas para /api/scheduled/*.
# Sem CRON_SECRET, os endpoints só aceitam o SDK da plataforma (Manus).
# CRON_SECRET=troque-por-outro-texto-aleatorio-bem-longo

# --- URL pública do app (opcional; Render seta sozinho via RENDER_EXTERNAL_URL) ---
# Necessário quando a IA precisa BAIXAR imagens que o usuário subiu (Memórias com
# fotos de atividades). Sem isso, o LLM recebe path relativo e ignora.
# APP_PUBLIC_URL=https://seu-dominio.com

# --- NÃO precisa mais (eram do Manus) ---
# OAUTH_SERVER_URL, VITE_OAUTH_PORTAL_URL, VITE_APP_ID,
# BUILT_IN_FORGE_API_URL, BUILT_IN_FORGE_API_KEY
# Deixe em branco/ausentes — o app usa Gemini + login por senha.
